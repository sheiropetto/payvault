{
  "name": "payvault",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "wrangler pages dev --local",
    "dev:all": "concurrently \"npm run dev:api\" \"sleep 3 && npm run dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "pages:dev": "wrangler pages dev --local",
    "deploy": "vite build",
    "db:migrate": "wrangler d1 migrations apply payvault-db",
    "db:seed": "wrangler d1 execute payvault-db --file=./migrations/seed.sql"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.0.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2",
    "lucide-react": "^0.400.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "recharts": "^2.12.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.9",
    "@types/react": "^18.3.3",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "vite": "^5.4.0",
    "wrangler": "^4.110.0"
  }
}
